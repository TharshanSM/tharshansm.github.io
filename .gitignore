# Raw screen recordings — NEVER commit. They expose the customer IFS hostname
# and, in REST/Network views, embed it inside scrolling response JSON.
# Only a reviewed, redacted clip may be added, and it must be listed explicitly below.
assets/*.mp4
assets/*.mkv
assets/*.mov
assets/*.webm
!assets/ifs-debug-console-demo-v3.mp4

# Large originals live in D:\Portfolio Masters, not in the repo.
# NOTE: Git is case-insensitive on Windows, so *.JPG also matches *.jpg —
# the debug-console poster is a real committed asset, so allow it explicitly.
assets/*.JPG
!assets/ifs-debug-console-poster-v3.jpg
assets/*_original.pdf
